{
  "name": "mcptap",
  "version": "0.0.0",
  "description": "The DevTools network tab for MCP. Records every tool call locally. Leaks nothing.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "mcptap": "./dist/cli.js"
  },
  "scripts": {
